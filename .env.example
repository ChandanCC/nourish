# Nouriq — Environment Variables
#
# Copy to .env (backend) and .env (frontend) as appropriate.
# See .plan/engineering/api-dependency-map.md for full context on each variable.
# See .plan/engineering/provider-abstraction.md for provider selection strategy.
#
# REQUIRED_NOW = app does not work without this
# PRODUCTION_ONLY = not needed for local dev
# FUTURE_OPTIONAL = not yet integrated

# ─────────────────────────────────────────────────────────────
# BACKEND (backend/.env)
# ─────────────────────────────────────────────────────────────

# ── AI Provider Selection ─────────────────────────────────────
# Controls which provider handles each capability.
# Supported values: anthropic (default), google, openai (future)
# To switch providers, change the value + supply the corresponding API key.
# No code changes required.

AI_PROVIDER_PARSING=anthropic
AI_PROVIDER_SYNTHESIS=anthropic

# Model selection per capability (provider-specific model identifiers)
AI_MODEL_PARSING=claude-sonnet-4-6
AI_MODEL_SYNTHESIS=claude-sonnet-4-6

# ── AI Provider Keys ──────────────────────────────────────────
# Only the key for the active provider(s) is required.
# Never reference these in frontend code.

ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=           (required if AI_PROVIDER_*=google)
# OPENAI_API_KEY=           (required if AI_PROVIDER_*=openai)

# ── Data ──────────────────────────────────────────────────────

# [REQUIRED_NOW] MongoDB Atlas — primary data store
# Local dev: mongodb://localhost:27017/nouriq
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/nouriq
MONGODB_URI=mongodb://localhost:27017/nouriq

# ── Authentication ────────────────────────────────────────────

# [REQUIRED_NOW] Google OAuth 2.0 — user authentication
# Obtain from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# [REQUIRED_NOW] JWT — session token signing
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_64_random_hex_chars

# ── Server ────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# [PRODUCTION_ONLY] CORS — set to frontend origin in production
# Local dev uses the Express default (localhost:5173 is allowed by config)
# FRONTEND_ORIGIN=https://app.nouriq.com

# ─────────────────────────────────────────────────────────────
# FRONTEND (frontend/.env)
# ─────────────────────────────────────────────────────────────

# [REQUIRED_NOW] Backend URL
# Local dev: http://localhost:3001
# Production: your API Gateway or Lambda URL
VITE_API_URL=http://localhost:3001

# [REQUIRED_NOW] Google OAuth Client ID (public — safe in frontend)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com

# ─────────────────────────────────────────────────────────────
# FUTURE — not yet integrated, do not add until roadmapped
# ─────────────────────────────────────────────────────────────

# [FUTURE_OPTIONAL] Nutritionix — barcode scanning (v2.0)
# NUTRITIONIX_APP_ID=
# NUTRITIONIX_APP_KEY=

# [FUTURE_OPTIONAL] Firebase Cloud Messaging — push notifications
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# [PRODUCTION_ONLY] Sentry — error tracking (optional; CloudWatch is default)
# SENTRY_DSN=

# ─────────────────────────────────────────────────────────────
# CI/CD ONLY — never in app runtime
# ─────────────────────────────────────────────────────────────

# AWS deployment (GitHub Actions secrets, not .env file)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
